# Catalog Atelier — local development environment

# Retrieval service admin surface (Phase 4.9.4)
RETRIEVAL_ADMIN_BASE_URL=http://localhost:8787
RETRIEVAL_ADMIN_SECRET=          # 32+ char token; production-only
# Falls back to RETRIEVAL_SHARED_SECRET if admin secret is unset (dev convenience)
RETRIEVAL_SHARED_SECRET=

# Toggle: when truthy, pages prefer live API; when missing, pages fall back
# to snapshots (docs/phase-4-reports). Default for local dev = "1".
NEXT_PUBLIC_CATALOG_USE_LIVE_API=1
