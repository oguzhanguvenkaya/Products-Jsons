{
  "version": "1.0",
  "description": "Schema for storing scraped URL data",

  "folder_structure": {
    "scraped_data": {
      "by_sku": {
        "description": "SKU bazlı scrape verileri",
        "structure": "{SKU}/url_{index}.json"
      },
      "by_url": {
        "description": "URL bazlı cache (tekrar scrape önleme)",
        "structure": "{domain}/{url_hash}.json"
      }
    }
  },

  "url_scrape_file_schema": {
    "metadata": {
      "sku": "string - Ürün SKU'su",
      "url": "string - Tam URL",
      "url_index": "number - URL sırası (0-4)",
      "scraped_at": "ISO 8601 timestamp",
      "scrape_duration_ms": "number - Scrape süresi",
      "http_status": "number - HTTP response kodu",
      "content_type": "string - Response content type",
      "content_length": "number - Byte cinsinden boyut",
      "final_url": "string - Redirect sonrası final URL (varsa)"
    },

    "verification": {
      "score": "number 0-1",
      "status": "accepted | rejected | needs_review",
      "checks": {
        "brand": {
          "searched": ["array of searched terms"],
          "found": "boolean",
          "matched_term": "string | null",
          "score": "number 0-1"
        },
        "product_name": {
          "keywords": ["array of keywords searched"],
          "matched_keywords": ["array of matched"],
          "match_ratio": "number 0-1",
          "score": "number 0-1"
        },
        "barcode": {
          "searched": "string - Barcode searched",
          "found": "boolean",
          "matched_format": "string | null",
          "score": "number 0-1"
        }
      },
      "rejection_reason": "string | null"
    },

    "content": {
      "language_detected": "string - en, de, tr, etc.",
      "page_title": "string - HTML title",
      "raw_markdown": "string - HTML to Markdown dönüşümü (tam içerik)",
      "raw_html_snippet": "string - Önemli bölümlerin HTML'i (opsiyonel, max 50KB)",
      "page_structure": {
        "has_specs_table": "boolean",
        "has_description": "boolean",
        "has_faq": "boolean",
        "has_related_products": "boolean",
        "has_reviews": "boolean"
      }
    },

    "extracted_data": {
      "product_name": "string - Sayfadaki ürün adı",
      "brand": "string - Tespit edilen marka",
      "barcode_found": "string | null",
      "price": {
        "value": "number | null",
        "currency": "string | null",
        "note": "Fiyat bilgisi referans amaçlı, kullanılmayacak"
      },
      "specs_raw": {
        "description": "Ham specs verisi - orijinal dilde",
        "format": "object - key:value pairs as found on page",
        "example": {
          "Cut": "10",
          "Finish": "6",
          "Silicone-free": "Yes"
        }
      },
      "description_raw": {
        "language": "string",
        "text": "string - Orijinal dilde tam açıklama"
      },
      "usage_instructions_raw": {
        "language": "string",
        "text": "string - Orijinal dilde kullanım talimatları"
      },
      "faq_raw": {
        "language": "string",
        "items": [
          {
            "question": "string",
            "answer": "string"
          }
        ]
      },
      "related_products_raw": {
        "items": ["array of product names/links found"]
      },
      "additional_info_raw": {
        "language": "string",
        "items": ["array of additional text blocks"]
      },
      "images": {
        "main_image": "string - URL",
        "gallery": ["array of image URLs"]
      }
    },

    "processing_notes": {
      "warnings": ["array of warning messages"],
      "errors": ["array of error messages"],
      "extraction_confidence": "high | medium | low"
    }
  },

  "merged_scraped_file_schema": {
    "description": "Tüm URL'lerden birleştirilmiş scrape verisi",
    "filename": "_scraped_merged.json",
    "content": {
      "sku": "string",
      "total_urls_attempted": "number",
      "successful_scrapes": "number",
      "failed_scrapes": "number",
      "sources": [
        {
          "url": "string",
          "status": "accepted | rejected",
          "language": "string",
          "data_types_found": ["specs", "description", "faq", "etc"]
        }
      ],
      "merged_specs": {
        "description": "Tüm kaynaklardan birleştirilmiş specs - HAM",
        "format": "object with source tracking",
        "example": {
          "abrasiveness": {
            "value": "10/10",
            "sources": ["menzerna.com", "carzilla.ca"],
            "original_terms": ["Cut: 10", "Abrasiveness: 10/10"]
          }
        }
      },
      "merged_descriptions": {
        "by_language": {
          "en": "string - English descriptions merged",
          "de": "string - German descriptions merged"
        }
      },
      "merged_faq": {
        "items": [
          {
            "question": "string",
            "answer": "string",
            "language": "string",
            "source": "string"
          }
        ]
      }
    }
  },

  "url_cache_schema": {
    "description": "URL bazlı cache - aynı URL'yi tekrar scrape etmemek için",
    "filename": "{url_hash}.json",
    "location": "scraped_data/by_url/{domain}/",
    "content": {
      "url": "string",
      "url_hash": "string - MD5 or SHA256",
      "first_scraped_at": "timestamp",
      "last_scraped_at": "timestamp",
      "scrape_count": "number",
      "used_by_skus": ["array of SKUs that use this URL"],
      "cached_content": "reference to full scrape data"
    }
  }
}
