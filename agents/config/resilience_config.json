{
  "version": "1.0",
  "description": "Token limiti ve sistem kesintilerine karşı dayanıklılık ayarları",

  "batch_processing": {
    "batch_size": 5,
    "reason": "Her batch'te max 5 ürün - token tüketimini kontrol altında tutar",
    "checkpoint_frequency": "after_each_product",
    "pause_between_batches_ms": 2000
  },

  "product_status_lifecycle": {
    "statuses": ["pending", "scraping", "enriching", "completed", "failed", "partial"],
    "transitions": {
      "pending": ["scraping"],
      "scraping": ["enriching", "failed", "partial"],
      "enriching": ["completed", "failed", "partial"],
      "partial": ["scraping", "enriching"],
      "failed": ["pending"]
    },
    "description": "Her ürün için atomik durum geçişleri - yarıda kalırsa 'partial' olarak işaretlenir"
  },

  "recovery_strategy": {
    "on_token_limit": {
      "action": "save_and_stop",
      "steps": [
        "1. Mevcut ürünü 'partial' olarak işaretle",
        "2. checkpoint.json'ı güncelle",
        "3. completed_skus.txt'yi güncelle",
        "4. Kullanıcıya bilgi ver",
        "5. Yeni session'da kaldığı yerden devam et"
      ]
    },
    "on_agent_failure": {
      "action": "retry_then_skip",
      "max_retries": 2,
      "steps": [
        "1. Hatayı logla (failed_skus.json)",
        "2. 2 kez tekrar dene",
        "3. Başarısızsa 'failed' olarak işaretle",
        "4. Sonraki ürüne geç",
        "5. Batch sonunda failed ürünleri raporla"
      ]
    },
    "on_url_timeout": {
      "action": "skip_url",
      "timeout_ms": 30000,
      "steps": [
        "1. URL'yi 'timeout' olarak işaretle",
        "2. Diğer URL'lere devam et",
        "3. Hiç URL çalışmazsa sadece full_description kullan"
      ]
    }
  },

  "checkpoint_content": {
    "required_fields": [
      "last_updated",
      "current_product_sku",
      "current_product_status",
      "current_phase",
      "completed_skus_count",
      "last_successful_sku"
    ],
    "save_trigger": "after_each_product_completion"
  },

  "session_resume_protocol": {
    "steps": [
      "1. checkpoint.json oku",
      "2. status == 'partial' olan ürünü bul",
      "3. O ürünün output JSON'ını oku",
      "4. Hangi fazda kaldığını belirle (scraped var mı? enriched var mı?)",
      "5. Kaldığı fazdan devam et",
      "6. completed_skus.txt ile çapraz kontrol yap"
    ]
  },

  "context_management": {
    "max_products_in_context": 5,
    "strategy": "process_then_forget",
    "description": "Her batch işlendikten sonra detaylar context'ten düşer, sadece özet kalır",
    "summary_format": {
      "after_batch": "Batch X tamamlandı: Y ürün işlendi, Z başarılı, W başarısız"
    }
  }
}
