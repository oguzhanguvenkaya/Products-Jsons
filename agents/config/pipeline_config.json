{
  "version": "1.1",
  "created_at": "2026-02-04",
  "updated_at": "2026-02-04",
  "description": "Product Data Enrichment Pipeline Configuration",

  "pipeline": {
    "phases": [
      {
        "phase": 0,
        "name": "data_analysis",
        "description": "Analyze source files and create mappings",
        "agents": []
      },
      {
        "phase": 1,
        "name": "url_scraping",
        "description": "Scrape URLs, verify products, save RAW data",
        "agents": ["url_scraper"],
        "save_raw_data": true
      },
      {
        "phase": 1.5,
        "name": "scrape_cleaning",
        "description": "Clean scraped raw data, remove noise, keep product content",
        "agents": ["scrape_cleaner"],
        "input": "agents/scraped_data/by_sku/",
        "output": "agents/cleaned_data/"
      },
      {
        "phase": 2,
        "name": "enrichment",
        "description": "Enrich product data with specs, content, and FAQ",
        "agents": ["description_enricher", "group_verifier", "specs_extractor", "content_filler", "faq_generator"],
        "parallel": false,
        "use_scraped_data": true
      },
      {
        "phase": 3,
        "name": "relations",
        "description": "Build product relations (requires full category)",
        "agents": ["relations_builder"]
      },
      {
        "phase": 4,
        "name": "validation",
        "description": "Validate and save final output",
        "agents": []
      }
    ],
    "agent_order": [
      "url_scraper",
      "scrape_cleaner",
      "description_enricher",
      "group_verifier",
      "specs_extractor",
      "content_filler",
      "faq_generator",
      "relations_builder"
    ]
  },

  "scraped_data_settings": {
    "enabled": true,
    "save_raw_markdown": true,
    "save_extracted_data": true,
    "save_per_url": true,
    "save_merged": true,
    "base_path": "agents/scraped_data",
    "by_sku_path": "agents/scraped_data/by_sku",
    "by_url_path": "agents/scraped_data/by_url",
    "file_naming": {
      "per_url": "url_{index}_{domain}.json",
      "merged": "_scraped_merged.json"
    },
    "content_limits": {
      "raw_markdown_max_chars": null,
      "note": "No limit - save everything"
    }
  },

  "batch_settings": {
    "batch_size": 10,
    "save_after_each_product": true,
    "save_after_each_batch": true,
    "retry_failed": true,
    "max_retries": 2
  },

  "processing_settings": {
    "skip_if_no_url": false,
    "skip_completed": true,
    "parallel_agents": false,
    "validate_json_output": true
  },

  "categories_priority": [
    "abrasive_polishes",
    "masking_tapes",
    "microfiber",
    "car_shampoo",
    "ceramic_coatings",
    "wax_sealants",
    "interior_care",
    "wheel_tire",
    "fragrance"
  ],

  "pilot_test": {
    "enabled": true,
    "category": "abrasive_polishes",
    "product_count": 5,
    "test_skus": [
      "22.746.281.001",
      "22.200.281.001",
      "22.203.261.001",
      "22.828.281.001",
      "22748.281.001"
    ]
  },

  "output_settings": {
    "by_sku_enabled": true,
    "by_category_enabled": true,
    "final_merge_enabled": true,
    "preserve_original_files": true,
    "output_paths": {
      "by_sku": "agents/output/by_sku",
      "by_category": "agents/output/by_category",
      "final": "agents/output/final"
    }
  },

  "logging": {
    "log_level": "info",
    "log_to_file": true,
    "log_file": "agents/logs/pipeline.log"
  },

  "source_files": {
    "all_categories": "all_categories.json",
    "products_specs": "products_specs_group.json",
    "urls_merged": "URLs_merged.csv",
    "products_barcode": "Products_with_barcode.csv"
  },

  "url_scraper_settings": {
    "verification_enabled": false,
    "verification_threshold": 0,
    "max_urls_per_product": 10,
    "timeout_ms": 30000,
    "retry_count": 2,
    "skip_domains": [],
    "save_all_urls": true,
    "note": "Verification disabled - scrape ALL URLs without filtering"
  }
}
