# Supabase — Dashboard → Settings → Database → Connection string (Transaction pooler, us-east-1)
# Connection string'i dashboard'dan kopyala, direkt yapıştır. Formatı açıkça yazma.
SUPABASE_DB_URL=

# Supabase REST API — Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — AI Studio API key (gemini-embedding-001, 768d için)
GEMINI_API_KEY=

# Microservice kendi config
PORT=8787
RETRIEVAL_SHARED_SECRET=          # en az 16 karakter, production'da openssl rand ile üret
LOG_LEVEL=info

# Optional
AXIOM_TOKEN=
AXIOM_DATASET=
